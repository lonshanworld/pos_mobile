# Security Settings
SECRET_KEY=change-this-to-a-random-secure-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Admin Credentials (CHANGE THESE!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Mobile API Tokens (comma-separated)
# Generate unique tokens for each deployment
MOBILE_API_TOKENS=mobile-token-example-1,mobile-token-example-2

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10

# Database
DATABASE_URL=crash_reports.db
